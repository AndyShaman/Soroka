#!/usr/bin/env bash
set -euo pipefail

# Soroka updater — runs ON the VPS, in the repo directory.
# Pulls latest code, rebuilds the container, refreshes /usr/local/bin/soroka-mcp.
#
# Usage:
#   cd ~/soroka     # or wherever you cloned it
#   ./bin/update

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_DIR"

if [[ $EUID -eq 0 ]]; then
  SUDO=""
elif sudo -n true 2>/dev/null; then
  SUDO="sudo -n"
else
  echo "✗ нужен root или passwordless sudo" >&2
  exit 1
fi

echo "→ git pull..."
git pull --ff-only

echo "→ Пересобираю контейнер..."
$SUDO docker compose up -d --build

echo "→ Обновляю /usr/local/bin/soroka-mcp..."
$SUDO cp scripts/soroka-mcp /usr/local/bin/
$SUDO chmod +x /usr/local/bin/soroka-mcp

echo "✓ обновлено"
