#!/usr/bin/env bash
set -euo pipefail

# Soroka installer — runs ON the VPS, in the directory where the repo
# was cloned. Sets up Docker, writes .env, starts the container.
#
# Usage:
#   ssh user@vps                                                 # любым способом
#   git clone https://github.com/AndyShaman/soroka.git
#   cd soroka
#   ./bin/install
#
# Optional flags (skip prompts):
#   --tg-token <TOKEN>      Telegram bot token (от @BotFather)
#   --owner-id <ID>         Твой личный Telegram ID (от @userinfobot)

TG_TOKEN=""
OWNER_ID=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tg-token) TG_TOKEN="$2"; shift 2;;
    --owner-id) OWNER_ID="$2"; shift 2;;
    *) echo "unknown flag: $1" >&2; exit 1;;
  esac
done

if [[ "$(uname -s)" != "Linux" ]]; then
  cat >&2 <<MSG

✗ bin/install запускается ПРЯМО НА VPS (Linux).

  Похоже, ты запустил его на своём Mac/Windows локально.
  Зайди сначала на сервер любым способом (ssh, web-консоль, PuTTY),
  и уже там:

    git clone https://github.com/AndyShaman/soroka.git
    cd soroka
    ./bin/install
MSG
  exit 1
fi

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_DIR"

# sudo prefix: пусто для root, sudo -n для passwordless. Иначе — фейл с подсказкой.
if [[ $EUID -eq 0 ]]; then
  SUDO=""
elif sudo -n true 2>/dev/null; then
  SUDO="sudo -n"
else
  cat >&2 <<MSG

✗ Нужен root или passwordless sudo на этом сервере.

  Варианты:
   • Зайти на VPS как root: ssh root@<host>
   • Или один раз настроить passwordless sudo текущему юзеру:
       echo "\$USER ALL=(ALL) NOPASSWD: ALL" | sudo tee /etc/sudoers.d/\$USER
       sudo chmod 440 /etc/sudoers.d/\$USER
MSG
  exit 1
fi

read_if_empty() {
  local var_name="$1" prompt="$2"
  if [[ -z "${!var_name}" ]]; then
    read -rp "$prompt: " value
    printf -v "$var_name" "%s" "$value"
  fi
}

echo "🐦 Soroka — installer"
echo
echo "Что я сейчас сделаю:"
echo "  • поставлю docker и docker compose (если ещё нет)"
echo "  • запишу .env в $REPO_DIR/.env"
echo "  • запущу контейнер soroka-bot"
echo "  • положу /usr/local/bin/soroka-mcp"
echo

echo "──────────────────────────────────────────────────────────────"
echo "1/2 → Токен Telegram-бота"
echo
echo "Получи у @BotFather: команда /newbot → длинная строка вида"
echo "  1234567:AAC××××××××××××××××××××××××××××××××××××"
echo
read_if_empty TG_TOKEN "Токен бота"

echo
echo "──────────────────────────────────────────────────────────────"
echo "2/2 → Твой Telegram-ID (число)"
echo
echo "Это ID твоего профиля. Узнай: напиши /start боту @userinfobot —"
echo "он пришлёт число вроде 123456789."
echo
read_if_empty OWNER_ID "Telegram-ID"

echo
echo "──────────────────────────────────────────────────────────────"
echo "→ Проверяю зависимости (что уже стоит — не трогаю)..."

NEED_DOCKER=0
NEED_COMPOSE=0
command -v docker >/dev/null 2>&1 || NEED_DOCKER=1
$SUDO docker compose version >/dev/null 2>&1 || NEED_COMPOSE=1

if (( NEED_DOCKER || NEED_COMPOSE )); then
  # Ждём, если apt сейчас занят (unattended-upgrades, daily timer и т.п.).
  # Не убиваем чужой процесс — просто терпеливо ждём.
  WAITED=0
  WARNED=0
  while $SUDO fuser /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/lib/apt/lists/lock /var/cache/apt/archives/lock >/dev/null 2>&1; do
    if (( WARNED == 0 )); then
      echo "  apt сейчас занят другим процессом — жду до 15 минут..."
      $SUDO fuser -v /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/cache/apt/archives/lock 2>&1 | head -10 || true
      WARNED=1
    fi
    if (( WAITED >= 900 )); then
      echo "  ✗ apt всё ещё занят после 15 минут." >&2
      exit 1
    fi
    sleep 10
    WAITED=$((WAITED + 10))
  done

  export DEBIAN_FRONTEND=noninteractive
  $SUDO apt-get update -qq 2>&1 | grep -vE '^(W:|N:|Get:|Ign:|Hit:)' || true
fi

if (( NEED_DOCKER )); then
  echo "  ставлю docker.io (engine из основных репо Ubuntu)..."
  $SUDO apt-get install -y -qq docker.io
fi

if (( NEED_COMPOSE )); then
  # docker compose v2 нужен как plugin. В разных версиях Ubuntu пакет
  # называется по-разному. Чтобы не лезть в системные sources.list.d/ —
  # ставим один бинарник в штатное место для plugins.
  echo "  ставлю docker compose v2 (бинарник от Docker Inc.)..."
  ARCH=$(uname -m)
  case "$ARCH" in
    x86_64|aarch64) ;;
    *) echo "  ✗ архитектура $ARCH не поддерживается официальным релизом" >&2; exit 1;;
  esac
  $SUDO mkdir -p /usr/local/lib/docker/cli-plugins
  $SUDO curl -fsSL \
    "https://github.com/docker/compose/releases/latest/download/docker-compose-linux-${ARCH}" \
    -o /usr/local/lib/docker/cli-plugins/docker-compose
  $SUDO chmod +x /usr/local/lib/docker/cli-plugins/docker-compose
fi

# soroka-mcp вызывается по SSH под текущим юзером и делает `docker exec`
# без sudo. Если юзер не в группе docker — отказ на /var/run/docker.sock.
# Идемпотентно добавляем. Свежий SSH-коннект подхватит автоматически.
# root и так имеет доступ — пропускаем.
if [[ $EUID -ne 0 ]] && ! id -nG | grep -qw docker; then
  echo "  добавляю $(id -un) в группу docker (для soroka-mcp без sudo)..."
  $SUDO usermod -aG docker "$(id -un)"
fi
echo "  ✓ зависимости готовы"

echo "→ Записываю .env..."
$SUDO tee .env >/dev/null <<ENV
TELEGRAM_BOT_TOKEN=$TG_TOKEN
OWNER_TELEGRAM_ID=$OWNER_ID
ENV
$SUDO chmod 600 .env

echo "→ Запускаю контейнер..."
$SUDO docker compose up -d --build

echo "→ Ставлю /usr/local/bin/soroka-mcp..."
$SUDO cp scripts/soroka-mcp /usr/local/bin/
$SUDO chmod +x /usr/local/bin/soroka-mcp

if $SUDO docker ps --format '{{.Names}}' | grep -q soroka-bot; then
  echo "  ✓ бот запущен"
fi

cat <<MSG

🎉 Готово!

Открой Telegram, найди своего бота и отправь /start.
Дальше всё настроишь в чате с ботом.

Обновлять бота:  cd $REPO_DIR && ./bin/update
MSG
